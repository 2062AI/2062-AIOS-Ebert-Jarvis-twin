# Copy this file to .env and fill in real values. .env is gitignored.
# Every secret lives here and ONLY here — never in code or the vault.

# Telegram (Episode 1)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Anthropic / Claude (wired Ep 1, first used Ep 2 via the LLM router)
ANTHROPIC_API_KEY=
# Multi-model routing (Ep 12). Router uses CLAUDE_MODEL for most tasks, CLAUDE_CODE_MODEL for code/content.
# Current Claude IDs: claude-sonnet-4-6 / claude-opus-4-8 / claude-haiku-4-5
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_CODE_MODEL=claude-opus-4-8
# Which LLM providers are active (comma-separated). Future: "claude,gemini,gpt"
ACTIVE_PROVIDERS=claude
LLM_MAX_TOKENS=1024

# Cost governor (enforced Ep 5). Kill switch trips above this daily spend.
DAILY_BUDGET_USD=10

# Vault location inside the container (bind-mounted from ../Jarvis-Vault)
VAULT_PATH=/vault

# Postgres (Episode 3). DATABASE_URL is built by docker-compose from this password.
# Pick anything long and random; it stays local to your machine.
POSTGRES_PASSWORD=

# GitHub auto-commit (Episode 6, V2 §19). PAT scope: "repo" (private) is enough.
# Token is used only at push-time, never written into .git/config.
GITHUB_TOKEN=
# Format: owner/name  (e.g. yourname/your-repo)
GITHUB_REPO=
# Commit author identity. Defaults to the agent if unset.
GIT_USER_NAME=Ebert Sebastian Jarvis Pennyworth
GIT_USER_EMAIL=you@example.com

# Scheduler (Episode 7). Cron expressions evaluated in REPORTS_TZ.
REPORTS_TZ=America/Chicago
MORNING_CRON=0 4 * * *
EVENING_CRON=0 20 * * *
# Weekly funding checkpoint (Season 4) — Fridays 10am by default.
FUNDING_CRON=0 10 * * 5

# Dashboard auth (Season 4 hardening). SESSION_SECRET: long random string used
# to sign session tokens. DASHBOARD_PASSWORD: what you type to log into the
# dashboard. Set both; without them the dashboard refuses logins.
SESSION_SECRET=
DASHBOARD_PASSWORD=

# Nightly backup (Season 4) — DB dump + vault snapshot to ../Jarvis-Backups.
BACKUP_CRON=0 3 * * *
BACKUP_KEEP=14

# System Test Standard §9.1 self-test reminder. Cron checks daily; the module
# only notifies when a full test is actually due (monthly cadence).
SYSTEM_TEST_CRON=0 9 * * *
SYSTEM_TEST_CADENCE_DAYS=30
SYSTEM_TEST_REMIND_COOLDOWN_DAYS=7

# Infra-level TIER 1 enforcement (security-posture.js).
#  WEB_BIND: host interface the dashboard port publishes on. Default 127.0.0.1
#    (localhost-only). Set 0.0.0.0 ONLY behind a TLS reverse proxy.
#  DASHBOARD_PUBLIC: set true when the dashboard is reachable beyond localhost.
#    When true, the engine REFUSES to start without auth, and warns without HTTPS.
#  PUBLIC_URL: the https://… address it's served at (signals HTTPS is in place).
WEB_BIND=127.0.0.1
DASHBOARD_PUBLIC=false
PUBLIC_URL=

# YouTube Data API v3 (read-only channel insights — src/youtube.js).
# Get a key: console.cloud.google.com → enable "YouTube Data API v3" →
# Credentials → API key (restrict it to that API). Public data only; no OAuth.
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL=@YourChannel
